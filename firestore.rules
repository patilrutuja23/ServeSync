rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - role: string (required, 'volunteer' or 'ngo')
    //   - displayName: string
    //   - photoURL: string
    //   - skills: list of strings
    //   - location: string
    //   - availability: string
    //   - bio: string
    //   - organizationName: string
    //   - createdAt: timestamp
    //
    // Collection: opportunities
    // Fields:
    //   - title: string (required)
    //   - description: string
    //   - requiredSkills: list of strings
    //   - location: string
    //   - dateTime: timestamp
    //   - ngoId: string (required)
    //   - ngoName: string (required)
    //   - createdAt: timestamp
    //
    // Collection: connections
    // Fields:
    //   - volunteerId: string (required)
    //   - ngoId: string (required)
    //   - opportunityId: string
    //   - status: string ('pending', 'accepted', 'rejected')
    //   - type: string ('request', 'invite')
    //   - message: string
    //   - createdAt: timestamp
    //
    // Collection: activities
    // Fields:
    //   - userId: string (required)
    //   - action: string
    //   - details: string
    //   - timestamp: timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "patilrutuja042@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['volunteer', 'ngo', 'admin'] &&
             (!('skills' in data) || data.skills is list) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() < 1000));
    }

function isValidConnection(data) {
      return data.keys().hasAll(['volunteerId', 'ngoId', 'status', 'type']) &&
             data.status in ['pending', 'accepted', 'rejected'] &&
             data.type in ['request', 'invite'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role != 'admin' || isAdmin());
      
      // Owner can update their own profile.
      // Partial updates (rating, completedTasks, fcmToken, eventsCompleted, impactPoints)
      // are allowed without full profile re-validation.
      allow update: if isAuthenticated() && (
        isOwner(userId) ||
        isAdmin()
      );
      
      allow delete: if isAdmin();
    }

    match /opportunities/{opportunityId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
                    get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ngo' &&
                    request.resource.data.ngoId == request.auth.uid &&
                    request.resource.data.title is string &&
                    request.resource.data.title.size() > 0;
      allow update: if isAuthenticated() && resource.data.ngoId == request.auth.uid;
      allow delete: if isAuthenticated() && (resource.data.ngoId == request.auth.uid || isAdmin());
    }

    match /connections/{connectionId} {
      // list queries (e.g. getDocs with where clauses) — allow authenticated users
      // The query itself scopes results; per-doc rules apply on get.
      allow list: if isAuthenticated();

      allow get: if isAuthenticated() && (
        request.auth.uid == resource.data.volunteerId ||
        request.auth.uid == resource.data.ngoId
      );

      allow create: if isAuthenticated() && isValidConnection(request.resource.data) && (
        (request.resource.data.type == 'request' && request.resource.data.volunteerId == request.auth.uid) ||
        (request.resource.data.type == 'invite' && request.resource.data.ngoId == request.auth.uid)
      );

      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.volunteerId ||
        request.auth.uid == resource.data.ngoId ||
        isAdmin()
      );

      allow delete: if isAuthenticated() && (
        request.auth.uid == resource.data.volunteerId ||
        request.auth.uid == resource.data.ngoId ||
        isAdmin()
      );
    }

    match /activities/{activityId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
    
    match /test/connection {
      allow read: if true;
    }

    // ── invites ──────────────────────────────────────────────────────────────
    // NGOs create invites; volunteers and NGOs can read their own; volunteers update status.
    match /invites/{inviteId} {
      allow read: if isAuthenticated() &&
                  (request.auth.uid == resource.data.ngoId ||
                   request.auth.uid == resource.data.volunteerId);
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() &&
                    request.resource.data.ngoId == request.auth.uid;
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.volunteerId ||
        request.auth.uid == resource.data.ngoId
      );
      allow delete: if isAuthenticated() && (
        request.auth.uid == resource.data.ngoId || isAdmin()
      );
    }

    // ── notifications ────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read, list: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    // ── chats ───────────────────────────────────────────────────────────────
    match /chats/{chatId} {
      // list queries: allow any authenticated user to query their own chats
      // (the where('participants','array-contains',uid) filter handles scoping)
      allow list: if isAuthenticated();

      // single doc get: only participants
      allow get: if isAuthenticated() &&
                 request.auth.uid in resource.data.participants;

      // create: creator must be a participant
      allow create: if isAuthenticated() &&
                    request.auth.uid in request.resource.data.participants;

      // update (e.g. lastMessage): only participants
      allow update: if isAuthenticated() &&
                    request.auth.uid in resource.data.participants;

      allow delete: if false;

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isAuthenticated() &&
                    request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        allow create: if isAuthenticated() &&
                      request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
                      request.resource.data.senderId == request.auth.uid &&
                      request.resource.data.text is string &&
                      request.resource.data.text.size() > 0;

        allow update, delete: if false;
      }
    }

    // ── workProofs ──────────────────────────────────────────────────────────
    // Anyone authenticated can read; only the owner can write/delete.
    match /workProofs/{proofId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.role in ['volunteer', 'ngo'] &&
                    request.resource.data.imageUrl is string &&
                    request.resource.data.imageUrl.size() > 0;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update: if false; // proofs are immutable once uploaded
    }

    // ── ngo_verification ────────────────────────────────────────────────────
    // NGO can create/read their own; admin can read ALL and update status.
    match /ngo_verification/{docId} {
      allow read: if isAuthenticated() &&
                  (request.auth.uid == resource.data.ngoId || isAdmin());
      allow create: if isAuthenticated() &&
                    request.resource.data.ngoId == request.auth.uid &&
                    get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ngo' &&
                    request.resource.data.documentUrl is string &&
                    request.resource.data.status == 'pending';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── posts ────────────────────────────────────────────────────────────────
    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.content is string &&
                    request.resource.data.content.size() > 0;
      // Allow likes/comments updates by any authenticated user
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated() &&
                    (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ── post_comments ────────────────────────────────────────────────────────
    match /post_comments/{commentId} {
      allow read, list: if isAuthenticated();
      allow create: if isAuthenticated() &&
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.text is string &&
                    request.resource.data.text.size() > 0;
      allow delete: if isAuthenticated() &&
                    (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if false;
    }

  } // end match /databases/{database}/documents
} // end service cloud.firestore
